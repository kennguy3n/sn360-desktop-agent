<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.sn360.desktop-agent</string>

    <key>ProgramArguments</key>
    <array>
        <string>/usr/local/bin/sda-agent</string>
        <string>--config</string>
        <string>/etc/sn360-desktop-agent/config.yaml</string>
    </array>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
        <key>Crashed</key>
        <true/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>5</integer>

    <key>StandardOutPath</key>
    <string>/var/log/sn360-desktop-agent/sda-agent.log</string>
    <key>StandardErrorPath</key>
    <string>/var/log/sn360-desktop-agent/sda-agent.err</string>

    <key>ProcessType</key>
    <string>Background</string>

    <key>LowPriorityIO</key>
    <true/>
</dict>
</plist>
