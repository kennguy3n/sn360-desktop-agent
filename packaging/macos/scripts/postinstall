#!/bin/bash
# macOS postinstall script for sda-agent.
#
# Creates the state/log directories, loads the launchd daemon, and
# kicks off the first run. Runs as root during installation.

set -e

LAUNCHD_LABEL="com.sn360.desktop-agent"
LAUNCHD_PLIST="/Library/LaunchDaemons/${LAUNCHD_LABEL}.plist"
SDA_HOME="/var/lib/sn360-desktop-agent"
SDA_LOG="/var/log/sn360-desktop-agent"
SDA_CONF="/etc/sn360-desktop-agent"

# Legacy wazuh-desktop-agent -> sn360-desktop-agent path migration and
# legacy launchd label cleanup run in the preinstall script, before
# pkgbuild expands the new payload into place. See
# packaging/macos/scripts/preinstall.

mkdir -p "$SDA_HOME" "$SDA_LOG" "$SDA_CONF" "$SDA_CONF/sca"
chown -R root:wheel "$SDA_HOME" "$SDA_LOG"
chmod 0750 "$SDA_HOME" "$SDA_LOG"
chmod 0755 "$SDA_CONF" "$SDA_CONF/sca"
if [ -f "$SDA_CONF/config.yaml" ]; then
    chmod 0644 "$SDA_CONF/config.yaml"
fi

# Unload any previous version before reloading, so upgrades pick up
# plist changes immediately.
if launchctl list "$LAUNCHD_LABEL" >/dev/null 2>&1; then
    launchctl unload "$LAUNCHD_PLIST" >/dev/null 2>&1 || true
fi
launchctl load -w "$LAUNCHD_PLIST"

exit 0
